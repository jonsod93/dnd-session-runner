# Notion integration token (Internal Integration Token from https://www.notion.so/my-integrations)
NOTION_API_KEY=ntn_xxxxxxxxxxxxx

# Authentication (set in Vercel env vars)
# Generate hash with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
AUTH_USERNAME=your-username
AUTH_PASSWORD_HASH=$2a$10$your-bcrypt-hash-here
JWT_SECRET=a-random-secret-string

# Spotify integration (optional) — enables playlist auto-play on Roll Initiative
# 1. Go to https://developer.spotify.com/dashboard and open your app
# 2. Add redirect URIs: http://localhost:5173/spotify-callback (dev) and https://<your-domain>/spotify-callback (prod)
# 3. Copy the Client ID below
# 4. Set VITE_SPOTIFY_PLAYLIST_URI to your playlist's Spotify URI (right-click playlist → Share → Copy Spotify URI)
# Leave blank to disable the feature entirely.
VITE_SPOTIFY_CLIENT_ID=your_client_id_here
VITE_SPOTIFY_PLAYLIST_URI=spotify:playlist:your_playlist_id_here

# Sound effect: drop a 1-2s MP3 at public/audio/roll-initiative.mp3 to enable the sound on Roll Initiative.
